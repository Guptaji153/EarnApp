<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- DB -->
        <property name="hibernate.connection.driver_class">
		com.mysql.jdbc.Driver
        </property>

       <property name="hibernate.connection.url">
    jdbc:mysql://localhost:3306/earnbyapps?useSSL=false&amp;allowPublicKeyRetrieval=true&amp;serverTimezone=UTC
</property>
       
       

        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">saurabh</property>

        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQL5Dialect
        </property>

        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
      <!--   <property name="hibernate.hbm2ddl.auto">validate</property>  -->
        
        <property name="hibernate.hbm2ddl.auto">update</property>
        

        <!-- MAPPINGS -->
        <mapping resource="com/app/earn/model/mapping/user.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/userPaymentDetails.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/userOtp.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/taskSubmission.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/task.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/referral.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/paymentOption.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/banner.hbm.xml"/>
        <mapping resource="com/app/earn/model/mapping/taskStats.hbm.xml"/>

    </session-factory>
</hibernate-configuration>
