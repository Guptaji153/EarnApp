<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.app.earn.pojo">

    <class name="UserOtp" table="user_otps">

        <!-- Primary Key -->
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>

        <!-- Reference (kept flat, no relation) -->
        <property name="userId" column="user_id" type="long"/>

        <!-- Contact identifiers -->
        <property name="email" column="email" type="string"/>
        <property name="mobile" column="mobile" type="string"/>

        <!-- OTP details -->
        <property name="otpValue" column="otp_value" type="string" not-null="true"/>
        <property name="purpose" column="purpose" type="string" not-null="true"/>

        <!-- Lifecycle -->
        <property name="expiresAt" column="expires_at" type="timestamp" not-null="true"/>
        <property name="isVerified" column="is_verified" type="boolean"/>

        <property name="createdAt" column="created_at" type="timestamp"/>

    </class>

</hibernate-mapping>
