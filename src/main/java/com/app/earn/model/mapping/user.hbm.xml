<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.app.earn.pojo">

    <class name="User" table="users">

        <!-- Primary Key -->
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>

        <!-- Basic fields -->
        <property name="email" column="email" type="string" not-null="true" unique="true"/>
        <property name="password" column="password" type="string" not-null="true"/>

        <property name="fullName" column="full_name" type="string"/>
        <property name="phone" column="phone" type="string"/>
        <property name="country" column="country" type="string"/>

        <property name="role" column="role" type="string"/>
        <property name="status" column="status" type="string"/>

        <property name="createdAt" column="created_at" type="timestamp"/>
        <property name="lastLoginAt" column="last_login_at" type="timestamp"/>

    </class>

</hibernate-mapping>
